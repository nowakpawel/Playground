# ======================
# Java
# ======================

# Compiled class files
*.class

# ======================
# C++
# ======================

# Ignore all files without extension (compiled binaries)
# BUT keep directories
* 
!*/

# Optional (if using IDEs later)
.idea/
out/
*.iml

# Re-allow source files
!*.java
!*.cpp
!*.h
!*.hpp
!*.md
!*.txt
!.gitignore
